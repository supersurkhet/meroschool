{
  "expo": {
    "name": "MeroSchool",
    "slug": "meroschool",
    "scheme": "meroschool",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "ios",
      "android"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a73e8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.surkhet.school",
      "infoPlist": {
        "NSCameraUsageDescription": "MeroSchool needs camera access to scan classroom QR codes"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a73e8",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "app.surkhet.school",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow MeroSchool to access your camera to scan QR codes"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "25ec35d1-d012-4cc2-87a5-8584201f6762"
      }
    }
  }
}
